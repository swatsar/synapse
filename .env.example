# Synapse Platform Environment Variables
# Copy this file to .env and fill in your values

# API Authentication
SYNAPSE_API_KEY=<generate-strong-random-key-128bit>

# Database Configuration
DATABASE_URL=postgresql://synapse_user:secure_password@localhost:5432/synapse
VECTOR_DB_URL=http://localhost:6333

# LLM Provider Keys (optional - use vault in production)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Security
SYNAPSE_SECRET_KEY=<generate-strong-random-secret>
JWT_SECRET=<generate-strong-random-jwt-secret>

# Cluster Configuration (for distributed mode)
CLUSTER_MODE=false
NODE_ID=node-1
CLUSTER_SECRET=<generate-cluster-secret>

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Logging
LOG_LEVEL=INFO
AUDIT_LOG_PATH=/var/log/synapse/audit.log
